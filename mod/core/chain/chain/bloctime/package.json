{
  "name": "bittime",
  "version": "1.0.0",
  "description": "Churn mechanism with multiplier curve and stake-time rewards",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "setup:ganache": "hardhat run scripts/setup-ganache.js --network ganache",
    "deploy:ganache": "hardhat run scripts/deploy.js --network ganache",
    "deploy:base": "hardhat run scripts/deploy.js --network base",
    "ganache:start": "docker-compose up -d ganache",
    "ganache:stop": "docker-compose stop ganache",
    "ganache:logs": "docker-compose logs -f ganache"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "hardhat": "^2.19.0",
    "dotenv": "^16.3.1"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.0"
  }
}