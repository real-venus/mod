{
  "name": "evocoin-protocol",
  "version": "1.0.0",
  "description": "EvoCoin - Hub-and-spoke token exchange with modular bonding curve tokenomics",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
    "deploy:testnet": "hardhat run scripts/deploy.js --network testnet",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network mainnet",
    "simulate": "hardhat run scripts/simulate.js",
    "simulate:5": "GENERATIONS=5 hardhat run scripts/simulate.js",
    "simulate:10": "GENERATIONS=10 hardhat run scripts/simulate.js",
    "clean": "hardhat clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "4.9.3",
    "dotenv": "^16.3.1"
  }
}
