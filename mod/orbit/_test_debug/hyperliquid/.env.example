# Hyperliquid API Configuration

# Network: testnet or mainnet
HYPERLIQUID_TESTNET=true

# Your wallet address (required for viewing positions)
HYPERLIQUID_WALLET_ADDRESS=

# API credentials (required for trading)
# Generate these at https://app.hyperliquid.xyz/API
HYPERLIQUID_API_KEY=
HYPERLIQUID_API_SECRET=

# Polymarket API Configuration

# Your private key for Polymarket trading (optional)
POLYMARKET_API_KEY=

# Server port
PORT=8002
