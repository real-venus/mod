# Network RPC URLs (using public endpoints)
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_RPC=https://mainnet.base.org

# Private key for deployer/operator account (optional - leave empty for local testing)
# Only required for actual deployment to testnet/mainnet
PRIVATE_KEY=f2a2f5b67e30aa8e1cf4e4cd7f9891bf578661a7bcf5f9d204962dda428c6878

# BaseScan API key (optional - only needed for contract verification on BaseScan)
# You can deploy and run the bridge without this
BASESCAN_API_KEY=

# Token configuration
TOKEN_NAME=Bridged Commune
TOKEN_SYMBOL=BCOM
INITIAL_SUPPLY=1000000000000000000

# API configuration
BRIDGE_API_URL=http://localhost:8000
