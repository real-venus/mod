{
    admin localhost:2099
}

modc2.com {
    @agent_api path /api/agent /api/agent/*
    handle @agent_api {
        uri strip_prefix /api/agent
        reverse_proxy agent-api:50117
    }
    @agent_app path /agent /agent/*
    handle @agent_app {
        reverse_proxy agent-api:3117
    }
    @bloctime_api path /api/bloctime /api/bloctime/*
    handle @bloctime_api {
        uri strip_prefix /api/bloctime
        reverse_proxy bloctime:8851
    }
    @bloctime_app path /bloctime /bloctime/*
    handle @bloctime_app {
        reverse_proxy bloctime:8852
    }
    @bridge_api path /api/bridge /api/bridge/*
    handle @bridge_api {
        uri strip_prefix /api/bridge
        reverse_proxy {$PM2_HOST:localhost}:8840
    }
    @bridge_app path /bridge /bridge/*
    handle @bridge_app {
        reverse_proxy {$PM2_HOST:localhost}:8841
    }
    @latexhub_api path /api/latexhub /api/latexhub/*
    handle @latexhub_api {
        uri strip_prefix /api/latexhub
        reverse_proxy latexhub-api:50200
    }
    @latexhub_app path /latexhub /latexhub/*
    handle @latexhub_app {
        reverse_proxy latexhub-api:3200
    }
    @openclaw_api path /api/openclaw /api/openclaw/*
    handle @openclaw_api {
        uri strip_prefix /api/openclaw
        reverse_proxy openclaw:50120
    }
    @openclaw_app path /openclaw /openclaw/*
    handle @openclaw_app {
        reverse_proxy openclaw:50121
    }
    @main_api path /api /api/*
    handle @main_api {
        uri strip_prefix /api
        reverse_proxy {$PM2_HOST:localhost}:8000
    }
    handle /* {
        reverse_proxy {$PM2_HOST:localhost}:3000
    }
}

api.modc2.com {
    @cors_preflight method OPTIONS

    header Access-Control-Allow-Origin "https://modc2.com"
    header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    header Access-Control-Allow-Headers "Content-Type, Accept, Authorization, token"
    header Access-Control-Max-Age "3600"

    handle @cors_preflight {
        respond 204
    }

    handle /bridge/* {
        uri strip_prefix /bridge
        reverse_proxy {$PM2_HOST:localhost}:8840
    }

    handle /* {
        reverse_proxy {$PM2_HOST:localhost}:8000
    }
}
