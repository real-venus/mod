{
    admin off
    auto_https off
}

# auto-generated by dev.serve() — DO NOT hand-edit; regenerated each run.
:8888 {
    @codex_api path /api/codex /api/codex/*
    handle @codex_api {
        uri strip_prefix /api/codex
        reverse_proxy 127.0.0.1:8830
    }
    @codex_app path /codex /codex/*
    handle @codex_app {
        reverse_proxy 127.0.0.1:8830
    }

    @dev_api path /api/dev /api/dev/*
    handle @dev_api {
        uri strip_prefix /api/dev
        reverse_proxy 127.0.0.1:8870
    }
    @dev_app path /dev /dev/*
    handle @dev_app {
        reverse_proxy 127.0.0.1:8870
    }

    handle / {
        redir /dev permanent
    }
    handle /* {
        respond "mod gateway — served: codex, dev" 200
    }
}
