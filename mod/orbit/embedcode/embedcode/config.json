{
  "name": "embedcode",
  "version": "1.0.0",
  "description": "Code embedding and semantic search with local models",
  "fns": ["forward", "embed", "search", "collections", "info", "delete", "serve", "app", "kill", "status"],
  "urls": {
    "api": "http://localhost:8920",
    "app": "http://localhost:3920"
  },
  "schema": {
    "embed": {
      "description": "Embed all code files in a path into a named collection",
      "params": {
        "path": "str - path to file or directory",
        "collection": "str? - collection name (auto-generated from path if omitted)",
        "chunk_size": "int - lines per chunk (default 512)",
        "overlap": "int - overlap lines between chunks (default 64)",
        "extensions": "list[str]? - file extensions to include"
      }
    },
    "search": {
      "description": "Search embeddings by natural language query",
      "params": {
        "query": "str - search query",
        "collection": "str? - limit to collection",
        "path": "str? - limit to path's collection",
        "top_k": "int - number of results (default 10)"
      }
    },
    "collections": {
      "description": "List all embedding collections"
    },
    "info": {
      "description": "Get info about a collection or the module",
      "params": {
        "collection": "str? - collection name"
      }
    },
    "delete": {
      "description": "Delete a collection",
      "params": {
        "collection": "str - collection name"
      }
    },
    "serve": {
      "description": "Start the FastAPI server",
      "params": {
        "port": "int? - API port (default 8920)",
        "dev": "bool - reload mode (default true)"
      }
    },
    "app": {
      "description": "Start the Next.js web app",
      "params": {
        "port": "int? - app port (default 3920)",
        "dev": "bool - dev mode (default true)"
      }
    },
    "kill": {
      "description": "Stop services",
      "params": {
        "target": "str - api/app/all (default all)"
      }
    },
    "status": {
      "description": "Check service status"
    }
  }
}
