{
    "name": "hippius",
    "version": "1.0.0",
    "description": "Hippius substrate node + S3-compatible decentralized storage",
    "port": 50142,
    "app_port": 50143,
    "urls": {
        "api": "http://localhost:50142",
        "app": "http://localhost:50143"
    },
    "fns": [
        "forward",
        "put",
        "get",
        "pin",
        "list",
        "rm",
        "start_node",
        "stop_node",
        "status",
        "node_status",
        "peers",
        "account",
        "balance",
        "install"
    ],
    "env": {
        "HIPPIUS_BIN": "path to hippius-node binary",
        "HIPPIUS_PATH": "node base path (default: ~/.hippius)",
        "HIPPIUS_RPC": "substrate RPC URL (default: http://127.0.0.1:9933)",
        "HIPPIUS_S3_ENDPOINT": "S3 gateway endpoint (default: https://s3.hippius.com)",
        "HIPPIUS_S3_KEY": "S3 access key ID",
        "HIPPIUS_S3_SECRET": "S3 secret access key",
        "HIPPIUS_S3_BUCKET": "S3 bucket (default: mod)",
        "HIPPIUS_IPFS_GATEWAY": "IPFS retrieval gateway (default: https://get.hippius.network)"
    },
    "endpoints": {
        "put": {
            "method": "POST",
            "auth": true,
            "docs": "Upload to S3/local node"
        },
        "get": {
            "method": "GET",
            "auth": false,
            "docs": "Retrieve by CID"
        },
        "pin": {
            "method": "POST",
            "auth": true,
            "docs": "Pin CID via ipfs pallet"
        },
        "list": {
            "method": "GET",
            "auth": false,
            "docs": "List recorded objects"
        },
        "status": {
            "method": "GET",
            "auth": false,
            "docs": "Module + daemon status"
        },
        "peers": {
            "method": "GET",
            "auth": false,
            "docs": "Substrate peers"
        }
    },
    "schema": "QmRrQbhiNRy6ofn2B1CrDs6WSztoVrxmiXjfaJ7qnug6wn",
    "gateway_port": 50143
}