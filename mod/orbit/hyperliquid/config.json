{
  "name": "hyperliquid",
  "version": "1.0.0",
  "description": "Hyperliquid DEX - market data, trading, vaults, and trader analytics",
  "fns": [
    "forward",
    "serve",
    "app",
    "kill",
    "status",
    "fetch_market_data",
    "fetch_orderbook",
    "fetch_candles",
    "fetch_all_mids",
    "fetch_user_state",
    "fetch_user_funding",
    "place_order",
    "market_order",
    "cancel_order",
    "cancel_all_orders",
    "modify_order",
    "get_open_orders",
    "get_user_fills",
    "get_position",
    "get_balance",
    "close_position",
    "list_vaults",
    "get_vault_details",
    "get_vault_performance",
    "get_top_vaults",
    "deposit_to_vault",
    "withdraw_from_vault",
    "analyze_vault",
    "get_leaderboard",
    "get_user_profile",
    "get_user_pnl_history",
    "search_traders_by_volume",
    "analyze_trader"
  ],
  "schema": {
    "forward": {
      "input": [
        {"name": "fn", "type": "str", "value": null},
        {"name": "kwargs", "type": "dict", "value": {}}
      ],
      "output": {"type": "Any", "value": null},
      "docs": "Generic function dispatch - call any fn by name"
    },
    "fetch_orderbook": {
      "input": [
        {"name": "symbol", "type": "str", "value": "BTC"}
      ],
      "output": {"type": "Dict", "value": null},
      "docs": "Fetch L2 orderbook for a symbol"
    },
    "place_order": {
      "input": [
        {"name": "symbol", "type": "str", "value": "_empty"},
        {"name": "is_buy", "type": "bool", "value": true},
        {"name": "size", "type": "float", "value": "_empty"},
        {"name": "price", "type": "float", "value": "_empty"},
        {"name": "order_type", "type": "str", "value": "limit"},
        {"name": "reduce_only", "type": "bool", "value": false}
      ],
      "output": {"type": "Dict", "value": null},
      "docs": "Place a limit order on Hyperliquid"
    },
    "market_order": {
      "input": [
        {"name": "symbol", "type": "str", "value": "_empty"},
        {"name": "is_buy", "type": "bool", "value": true},
        {"name": "size", "type": "float", "value": "_empty"},
        {"name": "slippage", "type": "float", "value": 0.05}
      ],
      "output": {"type": "Dict", "value": null},
      "docs": "Place a market order with slippage protection"
    },
    "analyze_trader": {
      "input": [
        {"name": "address", "type": "str", "value": "_empty"}
      ],
      "output": {"type": "Dict", "value": null},
      "docs": "Comprehensive trader analysis (profile, positions, fills, PnL)"
    },
    "analyze_vault": {
      "input": [
        {"name": "vault_address", "type": "str", "value": "_empty"}
      ],
      "output": {"type": "Dict", "value": null},
      "docs": "Comprehensive vault analysis (details, performance)"
    }
  },
  "api": {
    "port": 8919,
    "entrypoint": "uvicorn api:app --host 0.0.0.0 --port 8919"
  },
  "app": {
    "port": 3919,
    "framework": "nextjs"
  },
  "urls": {
    "api": "http://localhost:8919",
    "app": "http://localhost:3919"
  }
}
