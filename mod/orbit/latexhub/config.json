{
    "name": "latexhub",
    "version": "1.0.0",
    "description": "Local filesystem LaTeX document storage, compilation, and management hub.",
    "fns": [
        "save",
        "load",
        "ls",
        "rm",
        "compile",
        "search",
        "serve",
        "kill",
        "status"
    ],
    "schema": "QmWWjfjEAcarSMqjsiBsY18ZZxz898duMX81uvFZi52JbC",
    "urls": {
        "api": "http://localhost:50200",
        "app": "http://localhost:3200"
    },
    "port": 50200,
    "app_port": 3200,
    "endpoints": [
        {
            "path": "/health",
            "method": "GET",
            "description": "Health check"
        },
        {
            "path": "/docs",
            "method": "GET",
            "description": "List all documents"
        },
        {
            "path": "/docs",
            "method": "POST",
            "description": "Save a document"
        },
        {
            "path": "/docs/{name}",
            "method": "GET",
            "description": "Load a document"
        },
        {
            "path": "/docs/{name}",
            "method": "DELETE",
            "description": "Remove a document"
        },
        {
            "path": "/docs/{name}/compile",
            "method": "POST",
            "description": "Compile document to PDF"
        },
        {
            "path": "/docs/{name}/pdf",
            "method": "GET",
            "description": "Download compiled PDF"
        },
        {
            "path": "/search",
            "method": "GET",
            "description": "Search documents"
        },
        {
            "path": "/folders",
            "method": "GET",
            "description": "List folders"
        },
        {
            "path": "/status",
            "method": "GET",
            "description": "Service status"
        }
    ]
}