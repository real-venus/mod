{
    "name": "polymarket",
    "version": "2.0.0",
    "description": "Polymarket prediction market \u2014 Rust API + Next.js frontend",
    "port": 50091,
    "app_port": 3091,
    "urls": {
        "api": "http://localhost:50091",
        "app": "http://localhost:3091/polymarket"
    },
    "fns": [
        "serve",
        "kill",
        "status",
        "build",
        "logs",
        "search",
        "markets",
        "trending",
        "events",
        "active_traders",
        "forward"
    ],
    "endpoints": {
        "/health": {
            "method": "GET",
            "docs": "Health check"
        },
        "/active-traders": {
            "method": "GET",
            "docs": "Active traders pipeline (streaming/paged/json)"
        },
        "/?endpoint=markets": {
            "method": "GET",
            "docs": "Proxy: list markets (gamma-api)"
        },
        "/?endpoint=events": {
            "method": "GET",
            "docs": "Proxy: list events (gamma-api)"
        },
        "/?endpoint=activity": {
            "method": "GET",
            "docs": "Proxy: user activity (data-api)"
        },
        "/?endpoint=positions": {
            "method": "GET",
            "docs": "Proxy: user positions (data-api)"
        },
        "/?endpoint=prices-history": {
            "method": "GET",
            "docs": "Proxy: price history (clob)"
        }
    },
    "schema": "QmPgRYnAdGiLramXzVhFz624PwUsmsT7T5vR7eWCpJHjUy",
    "gateway_port": 3091
}