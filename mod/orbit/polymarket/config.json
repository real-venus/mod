{
    "name": "polymarket",
    "version": "1.0.0",
    "description": "Polymarket prediction market \u2014 trading, data, scraping, backtesting (Rust-powered)",
    "port": 50091,
    "app_port": 3091,
    "urls": {
        "api": "http://localhost:50091",
        "app": "http://localhost:3091"
    },
    "fns": [
        "search",
        "markets",
        "market",
        "trending",
        "by_liquidity",
        "ending_soon",
        "events",
        "event",
        "tags",
        "orderbook",
        "midpoint",
        "last_trade_price",
        "price_history",
        "buy",
        "sell",
        "market_buy",
        "market_sell",
        "place_order",
        "cancel",
        "cancel_all",
        "open_orders",
        "positions",
        "position_value",
        "trades",
        "get_user_positions",
        "get_user_trades",
        "discover",
        "scrape",
        "scrape_stop",
        "scrape_status",
        "stored_prices",
        "stored_trades",
        "stored_markets",
        "store_stats",
        "backtest",
        "build",
        "auth",
        "serve",
        "kill",
        "status",
        "test"
    ],
    "schema": "QmPT29aqyW9hmBB7Dbrtw4bpYDv32HJd5Q6hGS1hMuebhx",
    "endpoints": {
        "/health": {
            "method": "GET",
            "docs": "Health check"
        },
        "/markets": {
            "method": "GET",
            "docs": "List markets"
        },
        "/markets/{condition_id}": {
            "method": "GET",
            "docs": "Get single market"
        },
        "/search": {
            "method": "GET",
            "docs": "Search markets"
        },
        "/trending": {
            "method": "GET",
            "docs": "Trending by volume"
        },
        "/orderbook/{token_id}": {
            "method": "GET",
            "docs": "Get order book"
        },
        "/order": {
            "method": "POST",
            "docs": "Place limit order"
        },
        "/market-order": {
            "method": "POST",
            "docs": "Place market order"
        },
        "/positions": {
            "method": "GET",
            "docs": "Get positions"
        },
        "/trades": {
            "method": "GET",
            "docs": "Get trade history"
        },
        "/backtest": {
            "method": "POST",
            "docs": "Run backtest"
        }
    }
}