# PreFi App Environment Variables
# Copy to .env.local and fill in values after deployment

# WalletConnect Project ID (get at: https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# PreFi V3 Contract Addresses (auto-generated by deploy-v3.js)
NEXT_PUBLIC_PREFI_V3_ADDRESS=
NEXT_PUBLIC_STAKE_TOKEN_ADDRESS=
NEXT_PUBLIC_ORACLE_ADDRESS=

# API Backend URL
NEXT_PUBLIC_API_URL=http://localhost:8830

# Chain ID (8453=Base, 84532=Base Sepolia, 1337=Ganache)
NEXT_PUBLIC_CHAIN_ID=84532

# Optional: Custom RPC URLs
NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org
NEXT_PUBLIC_GANACHE_RPC=http://localhost:7545
