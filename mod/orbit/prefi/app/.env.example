# WalletConnect Project ID
# Get one at: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Base Mainnet Contract Addresses (fill after deployment)
NEXT_PUBLIC_PREFI_BASE=
NEXT_PUBLIC_ORACLE_BASE=
NEXT_PUBLIC_STAKE_TOKEN_BASE=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Base Sepolia Contract Addresses (fill after deployment)
NEXT_PUBLIC_PREFI_SEPOLIA=
NEXT_PUBLIC_ORACLE_SEPOLIA=
NEXT_PUBLIC_STAKE_TOKEN_SEPOLIA=

# Optional: Custom RPC URLs
NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org
